rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email in get(/databases/$(database)/documents/admins/emails).data.list;
    }
    
    // Helper function to get user's student ID
    function getUserStudentId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.studentId;
    }
    
    // Students collection - Admins can read/write all, students can read/write their own
    match /students/{studentId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && getUserStudentId() == studentId);
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || 
                       (isAuthenticated() && getUserStudentId() == studentId && 
                        resource.data.profileEditEnabled == true);
      allow delete: if isAdmin();
    }
    
    // Payments collection - Admins can read/write all, students can read their own
    match /payments/{paymentId} {
      allow read: if isAdmin() || 
                     (isAuthenticated() && 
                      get(/databases/$(database)/documents/payments/$(paymentId)).data.studentId == getUserStudentId());
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Pending Payments collection - Admins can read/write all
    match /pendingPayments/{paymentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Users collection - For storing user metadata
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if request.auth.uid == userId || isAdmin();
    }
    
    // Admins collection - Admin emails list
    match /admins/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Audit logs - Admins can read/write
    match /auditLogs/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Follow-ups collection - Admins can read/write
    match /followUps/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
