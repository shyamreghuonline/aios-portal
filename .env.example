# AIOS Portal Environment Variables

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Configuration
NEXT_PUBLIC_ADMIN_EMAILS=admin@aiosedu.com,admin2@aiosedu.com

# Application URL (for SMS links)
NEXT_PUBLIC_APP_URL=https://aios-portal.vercel.app

# SMS Provider Configuration
# Options: twilio, msg91, fast2sms, or leave blank for development mode
SMS_PROVIDER=

# Twilio Configuration (if using Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 Configuration (if using MSG91 - India)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=AIOSDB
MSG91_TEMPLATE_ID=your_template_id

# Fast2SMS Configuration (if using Fast2SMS - India)
FAST2SMS_API_KEY=your_fast2sms_api_key
